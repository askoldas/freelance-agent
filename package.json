{
  "name": "freelance-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "profile:validate": "tsx scripts/validate-professional-profile.ts",
    "profile:import": "tsx scripts/import-professional-profile.ts",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "next": "16.2.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "4.1.13"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.9",
    "prettier": "3.7.4",
    "tsx": "^4.22.4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
